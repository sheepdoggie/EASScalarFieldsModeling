{
  "schema": "rank3_workflow_protocol_v1",
  "protocol_id": "certification_operator_agent_approval_loop_v1",
  "protocol_version": "1.0.0",
  "status": "active",
  "purpose": "Data-driven operator-agent workflow for preparing, reviewing, approving, revising, and executing certification/admission modeling materials.",
  "authority": {
    "contract_is_controlling_authority": true,
    "protocol_controls_chat_workflow_not_eas_ontology": true,
    "path_add_remove_is_not_intrinsic_eas_ontology": true,
    "candidate_promotion_by_label_change_forbidden": true
  },
  "roles": {
    "modeling_chat": {
      "description": "Agent that drafts certification materials from the contract and framework for user/operator approval.",
      "may_execute_model_before_explicit_approval": false,
      "must_draft_chat_draftable_items": true,
      "must_mark_non_inventable_items_honestly": true
    },
    "user_operator": {
      "description": "Human operator who approves, rejects, or requests changes to the customized review packet and modeling plan.",
      "valid_decisions": ["approve", "revise", "reject"]
    }
  },
  "required_item_actions": {
    "chat_must_draft": [
      "admission_overlay_proposals",
      "initialization_settling_gate_proposal",
      "negative_control_overlay_proposals",
      "path_monitor_policy_proposal",
      "draft_modeling_plan",
      "approval_request_summary"
    ],
    "chat_must_mark_non_inventable_unless_framework_evidence_exists": [
      "non_candidate_mechanism_evidence",
      "admitted_kernel_evidence",
      "admitted_path_monitor_evidence"
    ],
    "operator_must_supply_or_confirm": [
      "signed_release_manifest",
      "release_public_key",
      "release_signature",
      "explicit_approval_decision"
    ]
  },
  "mandatory_sequence": [
    {
      "step": 1,
      "id": "read_contract_and_required_items",
      "actor": "modeling_chat",
      "action": "Read the modeling_intent contract and OPERATOR_REQUIRED_ITEMS.json.",
      "output_required": true,
      "may_execute_model_after_step": false
    },
    {
      "step": 2,
      "id": "generate_or_load_review_packet",
      "actor": "modeling_chat",
      "action": "Generate or load the operator review packet scaffold using the framework generator.",
      "output_required": true,
      "may_execute_model_after_step": false
    },
    {
      "step": 3,
      "id": "draft_chat_draftable_items",
      "actor": "modeling_chat",
      "action": "Draft every chat-draftable missing certification item from the contract and framework. Do not ask the user to draft items the chat can draft.",
      "output_required": true,
      "may_execute_model_after_step": false
    },
    {
      "step": 4,
      "id": "mark_non_inventable_items",
      "actor": "modeling_chat",
      "action": "For each item that cannot be honestly supplied from the framework, mark it absent/non-inventable and certification_usable=false with a reason.",
      "output_required": true,
      "may_execute_model_after_step": false
    },
    {
      "step": 5,
      "id": "validate_customized_packet_for_review",
      "actor": "modeling_chat",
      "action": "Validate the customized packet and produce CUSTOMIZED_PACKET_VALIDATION_REPORT.json.",
      "output_required": true,
      "may_execute_model_after_step": false
    },
    {
      "step": 6,
      "id": "return_to_user_for_approval",
      "actor": "modeling_chat",
      "action": "Return the customized packet, proposed plan, and validation report to the user/operator for approval.",
      "output_required": true,
      "must_wait_after_step": true,
      "may_execute_model_after_step": false
    },
    {
      "step": 7,
      "id": "wait_for_explicit_decision",
      "actor": "modeling_chat",
      "action": "Stop and wait for an explicit user/operator decision: approve, revise, or reject. Silence is never approval.",
      "output_required": true,
      "must_wait_after_step": true,
      "may_execute_model_after_step": false
    },
    {
      "step": 8,
      "id": "handle_revision_request",
      "actor": "modeling_chat",
      "condition": "decision == revise",
      "action": "Revise the customized packet according to the requested changes, revalidate it, return it again, and wait again.",
      "loops_to_step": 5,
      "may_execute_model_after_step": false
    },
    {
      "step": 9,
      "id": "handle_rejection",
      "actor": "modeling_chat",
      "condition": "decision == reject",
      "action": "Stop certification execution and report rejected/non-certifying status.",
      "terminal": true,
      "may_execute_model_after_step": false
    },
    {
      "step": 10,
      "id": "record_approval_decision",
      "actor": "modeling_chat",
      "condition": "decision == approve",
      "action": "Record USER_APPROVAL_DECISION.json binding the validated packet hash and approved plan hash.",
      "output_required": true,
      "may_execute_model_after_step": false
    },
    {
      "step": 11,
      "id": "validate_approval_decision",
      "actor": "framework",
      "condition": "decision == approve",
      "action": "Validate that the approval decision binds the current packet hash and approved plan hash.",
      "output_required": true,
      "may_execute_model_after_step": false
    },
    {
      "step": 12,
      "id": "execute_only_after_approval_gate",
      "actor": "framework",
      "condition": "approval_validation.approved_for_modeling == true and approval_validation.executable_for_certification == true",
      "action": "Begin certification modeling only after approval validation passes and release/contract gates also pass.",
      "may_execute_model_after_step": true
    }
  ],
  "forbidden_behaviors": [
    "run_before_explicit_approval",
    "treat_silence_as_approval",
    "treat_template_generation_as_approval",
    "treat_partial_approval_as_approval",
    "run_after_revision_request_without_revision_revalidation_and_reapproval",
    "promote_candidate_overlay_by_label_change",
    "promote_candidate_mechanism_by_label_change",
    "use_orientation_label_as_path_edit_trigger",
    "make_path_add_remove_intrinsic_framework_rule"
  ],
  "approval_decision_requirements": {
    "required_schema": "rank3_operator_agent_user_approval_decision_v1",
    "allowed_decisions": ["approve", "revise", "reject"],
    "approve_requires_packet_hash": true,
    "approve_requires_plan_hash": true,
    "revise_requires_revalidation_before_return": true,
    "reject_is_terminal_for_current_certification_attempt": true
  },
  "generated_instruction_requirements": {
    "must_include_mandatory_sequence": true,
    "must_include_forbidden_behaviors": true,
    "must_include_wait_for_approval_rule": true,
    "must_include_revision_loop_rule": true,
    "must_include_modeling_only_after_approval_rule": true
  }
}
